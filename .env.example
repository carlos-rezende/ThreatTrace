# ThreatTrace - Variáveis de Ambiente
# Copie para .env e configure

# Porta do servidor (padrão: 8090)
PORT=8090

# Obrigatório: Auth-Key da URLHaus API
# Obtenha em: https://auth.abuse.ch/
URLHAUS_AUTH_KEY=your-auth-key-here

# Opcional: Cache (padrão: 3600 segundos = 1 hora)
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=1000

# Opcional: Rate limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=1 minute
